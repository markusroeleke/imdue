# Manus API
MANUS_API_KEY=dein_manus_api_key_hier
MANUS_FORCE_SKILL_IDS=skill_id_1,skill_id_2
MANUS_PROJECT_ID=proj_abc123

# SSL (corporate proxy / Zertifikatsprüfung)
# Option A – eigenes CA-Bundle angeben (empfohlen):
# SSL_CA_BUNDLE=C:/certs/corporate-ca.crt
# Option B – Verifikation deaktivieren (nur in vertrauenswürdigen Netzen):
SSL_VERIFY=false

# Auth / JWT (Phase 2)
SECRET_KEY=ein_langer_zufaelliger_string_fuer_jwt

# Database (Phase 2) — NICHT als DATABASE_URL benennen, da Chainlit
# diesen Namen reserviert und eine PostgreSQL-Verbindung erwartet.
# APP_DATABASE_URL=sqlite+aiosqlite:///./due_diligence.db
GITHUB_TOKEN=<token>
GITHUB_OWNER=markusroeleke
GITHUB_REPO=imdue
GIT_REPO_URL=https://github.com/markusroeleke/imdue.git